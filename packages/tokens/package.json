{
  "name": "@dre/tokens",
  "version": "0.1.0",
  "description": "Design tokens for the DRE Design System (Figma → CSS / JS / JSON)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": "./dist/css/tokens.css",
    "./css/light": "./dist/css/tokens.light.css",
    "./css/dark": "./dist/css/tokens.dark.css",
    "./json/light": "./dist/json/tokens.light.json",
    "./json/dark": "./dist/json/tokens.dark.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "dev": "tsx watch scripts/build.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint yet'"
  },
  "devDependencies": {
    "style-dictionary": "^4.4.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
